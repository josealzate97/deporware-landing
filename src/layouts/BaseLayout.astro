---
import Navbar from "../components/Navbar.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  currentPath?: string;
}

const {
  title,
  description = "Landing corporativa de Deporware, software de gestion deportiva para clubes, escuelas y academias.",
  currentPath = "/"
} = Astro.props;
---

<!doctype html>

<html lang="es">

  <head>
    
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="/images/branding/icons/ico.png" type="image/png" />
    <title>{title}</title>

  </head>

  <body>

    <Navbar currentPath={currentPath} />

    <main>
      <slot />
    </main>

    <script>
      import gsap from "gsap";

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const splitWords = (element) => {
        const words = element.textContent?.trim().split(/\s+/) ?? [];
        element.textContent = "";

        words.forEach((word, index) => {
          const span = document.createElement("span");
          span.className = "hero-word";
          span.textContent = word;
          element.appendChild(span);

          if (index < words.length - 1) {
            element.appendChild(document.createTextNode(" "));
          }
        });

        return element.querySelectorAll(".hero-word");
      };

      if (!reduceMotion) {
        const animatedTypewriters = Array.from(document.querySelectorAll('[data-animate="typewriter"]'));
        const animatedTexts = Array.from(document.querySelectorAll('[data-animate="words"]'));
        const animatedCtas = document.querySelectorAll('[data-animate="cta"]');
        const animatedFeatureCards = document.querySelectorAll('[data-animate="feature-card"]');

        if (animatedTypewriters.length > 0 || animatedTexts.length > 0 || animatedCtas.length > 0 || animatedFeatureCards.length > 0) {
          const timeline = gsap.timeline({ defaults: { ease: "power3.out" } });

          animatedTypewriters.forEach((element, index) => {
            const fullText = element.textContent?.trim() ?? "";

            if (!fullText) {
              return;
            }

            element.textContent = "";
            element.classList.add("typewriter-active");
            element.setAttribute("aria-label", fullText);

            const textSpan = document.createElement("span");
            textSpan.className = "typewriter-text";

            const cursor = document.createElement("span");
            cursor.className = "typewriter-cursor";
            cursor.setAttribute("aria-hidden", "true");
            cursor.textContent = "|";

            element.append(textSpan, cursor);

            const state = { chars: 0 };
            const duration = Math.max(1.8, fullText.length * 0.04);
            const position = index === 0 ? 0 : "-=0.25";

            timeline.to(
              state,
              {
                chars: fullText.length,
                duration,
                ease: "none",
                onUpdate: () => {
                  textSpan.textContent = fullText.slice(0, Math.floor(state.chars));
                }
              },
              position
            );

            timeline.to(cursor, { opacity: 0, duration: 0.14, repeat: 5, yoyo: true, ease: "none" }, "<0.35");
          });

          animatedTexts.forEach((element, index) => {
            const words = splitWords(element);
            timeline.from(words, { opacity: 0, y: 34, stagger: 0.022, duration: 0.62 }, index === 0 ? "-=0.28" : "-=0.42");
          });

          if (animatedCtas.length > 0) {
            timeline.from(
              animatedCtas,
              { opacity: 0, y: 18, scale: 0.92, stagger: 0.1, duration: 0.5, transformOrigin: "center center" },
              "-=0.28"
            );
          }

          if (animatedFeatureCards.length > 0) {
            timeline.from(
              animatedFeatureCards,
              { opacity: 0, y: 26, stagger: 0.08, duration: 0.55 },
              "-=0.2"
            );
          }
        }
      }
    </script>

  </body>

</html>
