---
import Navbar from "../components/Navbar.astro";
import WhatsAppFloatButton from "../components/WhatsAppFloatButton.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  currentPath?: string;
}

const {
  title,
  description = "Landing corporativa de Deporware, software de gestion deportiva para clubes, escuelas y academias.",
  currentPath = "/"
} = Astro.props;
---

<!doctype html>

<html lang="es">

  <head>
    
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="/images/branding/icons/ico.png" type="image/png" />
    <title>{title}</title>

  </head>

  <body>

    <Navbar currentPath={currentPath} />

    <main>
      <slot />
    </main>

    <WhatsAppFloatButton />

    <script>
      import gsap from "gsap";

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const splitWords = (element) => {
        const words = element.textContent?.trim().split(/\s+/) ?? [];
        element.textContent = "";

        words.forEach((word, index) => {
          const span = document.createElement("span");
          span.className = "hero-word";
          span.textContent = word;
          element.appendChild(span);

          if (index < words.length - 1) {
            element.appendChild(document.createTextNode(" "));
          }
        });

        return element.querySelectorAll(".hero-word");
      };

      if (!reduceMotion) {
        const animatedElements = Array.from(document.querySelectorAll("[data-animate]"));
        const animatedState = new WeakSet();

        const runTypewriter = (element) => {
          const fullText = element.textContent?.trim() ?? "";

          if (!fullText) {
            return;
          }

          element.textContent = "";
          element.classList.add("typewriter-active");
          element.setAttribute("aria-label", fullText);

          const textSpan = document.createElement("span");
          textSpan.className = "typewriter-text";

          const cursor = document.createElement("span");
          cursor.className = "typewriter-cursor";
          cursor.setAttribute("aria-hidden", "true");
          cursor.textContent = "|";

          element.append(textSpan, cursor);

          const state = { chars: 0 };
          const duration = Math.max(2.4, fullText.length * 0.05);

          const timeline = gsap.timeline({ defaults: { ease: "none" } });
          timeline.to(state, {
            chars: fullText.length,
            duration,
            ease: "none",
            onUpdate: () => {
              textSpan.textContent = fullText.slice(0, Math.floor(state.chars));
            }
          });
          timeline.to(cursor, { opacity: 0.5, duration: 0.25, ease: "none" }, "<0.1");
        };

        const runWords = (element, isHeroTitle = false) => {
          const words = splitWords(element);

          if (isHeroTitle) {
            gsap.from(words, {
              opacity: 0,
              y: 6,
              stagger: 0.018,
              duration: 0.72,
              ease: "power1.out"
            });
            return;
          }

          gsap.from(words, {
            opacity: 0,
            y: 6,
            stagger: 0.012,
            duration: 0.62,
            ease: "power1.out"
          });
        };

        const runAnimation = (element) => {
          if (animatedState.has(element)) {
            return;
          }

          const type = element.getAttribute("data-animate");
          animatedState.add(element);

          if (type === "typewriter") {
            runTypewriter(element);
            return;
          }

          if (type === "words") {
            runWords(element, false);
            return;
          }

          if (type === "hero-title") {
            runWords(element, true);
            return;
          }

          if (type === "cta") {
            gsap.from(element, {
              opacity: 0,
              y: 6,
              duration: 0.52,
              transformOrigin: "center center",
              ease: "power1.out"
            });
            return;
          }

          if (type === "feature-card") {
            gsap.from(element, {
              opacity: 0,
              y: 6,
              duration: 0.58,
              ease: "power1.out"
            });
          }
        };

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) {
                return;
              }

              runAnimation(entry.target);
              observer.unobserve(entry.target);
            });
          },
          {
            // Trigger when elements reach around mid-screen while scrolling
            rootMargin: "0px 0px -45% 0px",
            threshold: 0.1
          }
        );

        animatedElements.forEach((element) => observer.observe(element));
      }
    </script>

  </body>

</html>
