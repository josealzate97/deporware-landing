---
const rawNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? "";
const whatsappNumber = String(rawNumber).replace(/\D/g, "");
const defaultMessage = "Hola, me interesa Deporware y quisiera recibir mas informacion.";
const message = import.meta.env.PUBLIC_WHATSAPP_MESSAGE ?? defaultMessage;

const whatsappHref = whatsappNumber
  ? `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(message)}`
  : "/#contacto";
const openInNewTab = Boolean(whatsappNumber);
---

<a
  class="whatsapp-float-button"
  href={whatsappHref}
  target={openInNewTab ? "_blank" : undefined}
  rel={openInNewTab ? "noopener noreferrer" : undefined}
  aria-label="Hablar por WhatsApp con Deporware"
  title="Escribenos por WhatsApp"
>
  <svg viewBox="0 0 32 32" aria-hidden="true" focusable="false">
    <path d="M16 3C8.82 3 3 8.66 3 15.65c0 2.57.79 5.08 2.29 7.2L3.2 29l6.4-2.02a13.2 13.2 0 0 0 6.4 1.65c7.18 0 13-5.66 13-12.65S23.18 3 16 3Zm0 23.25c-2 0-3.97-.54-5.67-1.54l-.4-.24-3.8 1.2 1.26-3.66-.26-.37a10.96 10.96 0 0 1-1.76-5.99c0-5.74 4.76-10.4 10.63-10.4 5.86 0 10.63 4.66 10.63 10.4S21.86 26.25 16 26.25Zm5.83-7.91c-.32-.16-1.9-.94-2.2-1.05-.3-.1-.51-.16-.73.16-.22.31-.84 1.04-1.04 1.25-.19.2-.38.23-.7.08-.32-.16-1.35-.48-2.58-1.53-.95-.82-1.6-1.82-1.78-2.13-.19-.31-.02-.48.14-.63.14-.14.32-.36.48-.53.16-.18.21-.32.32-.53.1-.2.05-.39-.03-.55-.08-.16-.73-1.75-1-2.39-.26-.62-.52-.54-.73-.55h-.62c-.21 0-.55.08-.83.39s-1.1 1.06-1.1 2.58 1.13 2.99 1.29 3.2c.15.2 2.2 3.46 5.44 4.7.77.3 1.37.48 1.83.62.77.24 1.47.2 2.03.12.62-.1 1.9-.78 2.17-1.53.27-.75.27-1.39.18-1.53-.08-.14-.3-.22-.62-.38Z" />
  </svg>
</a>