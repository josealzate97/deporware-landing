---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Deporware | Valores"
  currentPath="/valores"
  description="Mision, vision y principios que guian a Deporware."
>
  <section class="page-hero section">
    <div class="container narrow">
      <p class="eyebrow">Valores</p>
      <h1 data-animate="words">Mision, vision y principios que guian a Deporware.</h1>
      <p class="lead" data-animate="words">
        Queremos construir una base digital confiable para equipos que necesitan gestionar mejor su
        informacion deportiva.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container value-stack">
      <article class="value-card">
        <h2 data-animate="words">Mision</h2>
        <p>
          Brindar a clubes y escuelas un sistema claro para gestionar usuarios, fichas deportivas,
          entrenamientos y procesos operativos desde un solo lugar.
        </p>
      </article>

      <article class="value-card">
        <h2 data-animate="words">Vision</h2>
        <p>
          Ser una plataforma referente en gestion deportiva para organizaciones que buscan orden, control y
          decisiones respaldadas por datos.
        </p>
      </article>

      <article class="value-card">
        <h2 data-animate="words">Principios</h2>
        <p>
          Diseñar con claridad, construir con enfoque practico y mantener la tecnologia al servicio de la
          operacion real del deporte.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
